<Window x:Class="NoFocusLossGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoFocusLoss" Height="660" Width="860"
        MinHeight="540" MinWidth="720"
        WindowStyle="None" AllowsTransparency="False"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Foreground="#FFFFFFFF">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" ResizeBorderThickness="5" UseAeroCaptionButtons="False" GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ── Brushes ── -->
        <SolidColorBrush x:Key="AccentBrush"        Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentHoverBrush"   Color="#1A86D8"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#006CBD"/>
        <SolidColorBrush x:Key="OrangeBrush"        Color="#C45911"/>
        <SolidColorBrush x:Key="GreenBrush"         Color="#0D7A0D"/>
        <SolidColorBrush x:Key="GreenHoverBrush"    Color="#178A17"/>
        <SolidColorBrush x:Key="PurpleBrush"        Color="#744DA9"/>
        <SolidColorBrush x:Key="PurpleHoverBrush"   Color="#8657B8"/>
        <SolidColorBrush x:Key="CardBrush"          Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush"    Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="TitleBarBrush"      Color="#0AFFFFFF"/>
        <SolidColorBrush x:Key="SubtleBrush"        Color="#0DFFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary"        Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary"      Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="ListHoverBrush"     Color="#0FFFFFFF"/>
        <SolidColorBrush x:Key="ListSelectedBrush"  Color="#260078D4"/>

        <!-- ── Accent Button Template ── -->
        <ControlTemplate x:Key="AccentBtnTpl" TargetType="Button">
            <Border x:Name="Root" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}"
                    BorderBrush="#22FFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="Icon" Text="{TemplateBinding Tag}"
                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,7,0"
                               Foreground="{TemplateBinding Foreground}"/>
                    <ContentPresenter VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Root" Property="Opacity" Value="0.72"/>
                    <Setter TargetName="Root" Property="RenderTransform">
                        <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="50" CenterY="16"/></Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Root" Property="Opacity" Value="0.36"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Green inject button -->
        <Style x:Key="GreenBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource GreenBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Padding"      Value="18,10"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template"     Value="{StaticResource AccentBtnTpl}"/>
        </Style>

        <!-- Blue inject button -->
        <Style x:Key="BlueBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Padding"      Value="18,10"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template"     Value="{StaticResource AccentBtnTpl}"/>
        </Style>

        <!-- Purple inject button -->
        <Style x:Key="PurpleBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource PurpleBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Padding"      Value="18,10"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template"     Value="{StaticResource AccentBtnTpl}"/>
        </Style>

        <!-- Orange inject button -->
        <Style x:Key="OrangeBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource OrangeBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Padding"      Value="18,10"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template"     Value="{StaticResource AccentBtnTpl}"/>
        </Style>

        <!-- Subtle button (Refresh / Unload) -->
        <Style x:Key="SubtleBtn" TargetType="Button">
            <Setter Property="Background"    Value="{StaticResource SubtleBrush}"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding"       Value="14,7"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template"      Value="{StaticResource AccentBtnTpl}"/>
        </Style>

        <!-- Window control buttons -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"         Value="46"/>
            <Setter Property="Height"        Value="32"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close window button -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListBox item -->
        <Style x:Key="ProcItem" TargetType="ListBoxItem">
            <Setter Property="Padding"          Value="12,9"/>
            <Setter Property="Margin"           Value="0,1"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ListHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ListSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox -->
        <Style x:Key="ProcList" TargetType="ListBox">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ProcItem}"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin"       Value="4,0,0,6"/>
        </Style>

        <!-- Card border -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="6"/>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════ Root ═══════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Title bar -->
            <RowDefinition Height="*"/>    <!-- Content    -->
        </Grid.RowDefinitions>

        <!-- ── Title Bar ── -->
        <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <!-- App icon placeholder (circle accent) -->
                <Ellipse Width="22" Height="22" Fill="{StaticResource AccentBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="NoFocusLoss" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Window control buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Style="{StaticResource WinBtn}" Content="&#xE921;" Click="MinimizeClick"/>
                <Button Style="{StaticResource WinBtn}" x:Name="MaxRestoreBtn" Content="&#xE922;" Click="MaxRestoreClick"/>
                <Button Style="{StaticResource CloseBtn}" Content="&#xE8BB;" Click="CloseClick"/>
            </StackPanel>
        </Grid>

        <!-- ── Content ── -->
        <Grid Grid.Row="1" Margin="16,12,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Available header -->
                <RowDefinition Height="*"/>     <!-- Available list  -->
                <RowDefinition Height="Auto"/>  <!-- Action buttons  -->
                <RowDefinition Height="Auto"/>  <!-- Injected header -->
                <RowDefinition Height="*"/>     <!-- Injected list   -->
                <RowDefinition Height="Auto"/>  <!-- Unload row      -->
            </Grid.RowDefinitions>

            <!-- Available header -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <TextBlock Style="{StaticResource SectionHeader}" Text="AVAILABLE PROCESSES" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource SubtleBtn}" Tag="&#xE72C;"
                        Content="Refresh" HorizontalAlignment="Right" Click="Refresh"/>
            </Grid>

            <!-- Available list card -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
                <ListBox x:Name="Processes" Style="{StaticResource ProcList}" MaxHeight="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding}" FontSize="12"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="#14FFFFFF" CornerRadius="4" Padding="6,2">
                                    <TextBlock FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="64-bit"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- ── Inject Action Buttons ── -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}" Text="INJECT INTO SELECTED PROCESS"/>

                    <UniformGrid Grid.Row="2" Columns="2" Rows="2" HorizontalAlignment="Stretch">
                        <!-- Fix Focus Loss -->
                        <Button x:Name="BtnFocus" Style="{StaticResource GreenBtn}"
                                Tag="&#xE7FC;" Margin="0,0,4,4"
                                Click="InjectFocus">
                            <TextBlock><Run Text="Fix Focus Loss"/></TextBlock>
                        </Button>

                        <!-- Bypass Screenshot -->
                        <Button x:Name="BtnScreenshot" Style="{StaticResource PurpleBtn}"
                                Tag="&#xE722;" Margin="4,0,0,4"
                                Click="InjectScreenshot">
                            <TextBlock><Run Text="Bypass Screenshot"/></TextBlock>
                        </Button>

                        <!-- Enable Text Copy -->
                        <Button x:Name="BtnTextCopy" Style="{StaticResource OrangeBtn}"
                                Tag="&#xE8C8;" Margin="0,4,4,0"
                                Click="InjectTextCopy">
                            <TextBlock><Run Text="Enable Text Copy"/></TextBlock>
                        </Button>

                        <!-- Both / All Features -->
                        <Button x:Name="BtnBoth" Style="{StaticResource BlueBtn}"
                                Tag="&#xE734;" Margin="4,4,0,0"
                                Click="InjectBoth">
                            <TextBlock><Run Text="All Features"/></TextBlock>
                        </Button>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- Injected header -->
            <Grid Grid.Row="3" Margin="0,0,0,6">
                <TextBlock Style="{StaticResource SectionHeader}" Text="INJECTED PROCESSES" VerticalAlignment="Center"/>
                <Button Style="{StaticResource SubtleBtn}" Tag="&#xE74D;"
                        Content="Unload" HorizontalAlignment="Right" Click="Unload"/>
            </Grid>

            <!-- Injected list card -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <ListBox x:Name="InjectedProcesses" Style="{StaticResource ProcList}"/>
            </Border>

            <!-- Status bar -->
            <TextBlock Grid.Row="5" x:Name="StatusText"
                       Text="Ready — select a process and choose an action"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="11" Margin="4,8,0,0"/>
        </Grid>
    </Grid>
</Window>
